# API URL (backend)
VITE_API_URL=http://localhost:8010

# Hub SSO (enable to show Hub login button)
VITE_SSO_HUB_ENABLED=true

# Other SSO providers (optional)
# VITE_SSO_GOOGLE_CLIENT_ID=your-google-client-id
# VITE_SSO_MICROSOFT_CLIENT_ID=your-microsoft-client-id
# VITE_SSO_GITHUB_CLIENT_ID=your-github-client-id
# VITE_SSO_KEYCLOAK_URL=https://your-keycloak-server/realms/your-realm
# VITE_SSO_KEYCLOAK_CLIENT_ID=your-keycloak-client-id
