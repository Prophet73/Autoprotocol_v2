# =============================================================================
# WhisperX Production Environment Variables
# =============================================================================
# Copy this file to .env.production and fill in real values
# NEVER commit .env.production to git!
# =============================================================================

# === API KEYS (REQUIRED) ===
HUGGINGFACE_TOKEN=hf_your_token_here
GEMINI_API_KEY=your_gemini_api_key_here

# === SECURITY (REQUIRED - CHANGE THESE!) ===
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=CHANGE_ME_generate_with_python_secrets
POSTGRES_PASSWORD=CHANGE_ME_strong_password_here
FLOWER_USER=admin
FLOWER_PASSWORD=CHANGE_ME_flower_password

# === CORS (REQUIRED) ===
# Your production domain(s), comma-separated
CORS_ORIGINS=https://test1.dev.svrd.ru

# === ENVIRONMENT ===
ENVIRONMENT=production
LOG_LEVEL=WARNING

# === MODEL CONFIGURATION ===
WHISPER_MODEL=large-v3
COMPUTE_TYPE=float16
DEVICE=cuda
BATCH_SIZE=16

# === VAD CONFIGURATION ===
VAD_THRESHOLD=0.5
VAD_MIN_SPEECH_MS=250

# === QUALITY ===
SCORE_THRESHOLD=0.25

# === TRANSLATION ===
TRANSLATION_CONTEXT_WINDOW=3

# === OPTIONAL: External services ===
# SSO_HUB_URL=https://hub.example.com
# SSO_HUB_ENABLED=true
