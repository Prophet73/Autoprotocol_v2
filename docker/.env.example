# =============================================================================
# WhisperX Production Environment Template
# =============================================================================
# Скопируйте этот файл в .env.production и заполните значения:
#   cp .env.example .env.production
# =============================================================================

# === ENVIRONMENT ===
ENVIRONMENT=production
DEBUG=False
LOG_LEVEL=WARNING

# === API KEYS (ОБЯЗАТЕЛЬНО!) ===
# HuggingFace токен для pyannote (диаризация)
# Получить: https://huggingface.co/settings/tokens
HUGGINGFACE_TOKEN=hf_YOUR_TOKEN_HERE

# Google Gemini API ключ (перевод и генерация отчётов)
# Получить: https://aistudio.google.com/apikey
GEMINI_API_KEY=AIzaSy_YOUR_KEY_HERE
GEMINI_MODEL_NAME=gemini-2.5-pro
GEMINI_REPORT_MODEL=gemini-2.5-pro
GEMINI_TRANSLATE_MODEL=gemini-2.5-flash
GEMINI_FALLBACK_MODELS=gemini-2.5-flash
GOOGLE_API_KEY=AIzaSy_YOUR_KEY_HERE

# === SECURITY (ОБЯЗАТЕЛЬНО СГЕНЕРИРОВАТЬ!) ===
# Сгенерировать: python3 -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=CHANGE_ME_GENERATE_NEW_KEY
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# === DATABASE ===
# Пароль PostgreSQL (измените на сложный!)
POSTGRES_PASSWORD=change_me_strong_password

# === CORS ===
# Укажите ваш домен!
CORS_ORIGINS=https://your-domain.ru,http://localhost:3001

# === TRANSCRIPTION ===
# GPU (production): large-v3, float16, cuda
# CPU (тест): tiny, int8, cpu
WHISPER_MODEL=large-v3
COMPUTE_TYPE=float16
DEVICE=cuda
BATCH_SIZE=16

# === VAD ===
VAD_THRESHOLD=0.5
VAD_MIN_SPEECH_MS=250

# === QUALITY ===
SCORE_THRESHOLD=0.25

# === TRANSLATION ===
TRANSLATION_CONTEXT_WINDOW=3

# === DIARIZATION ===
ENABLE_DIARIZATION=True
DIARIZATION_MODEL=pyannote/speaker-diarization-3.1

# === STORAGE ===
STORAGE_TYPE=local
STORAGE_PATH=/data/storage

# === EMAIL (SMTP) - опционально ===
MAIL_SERVER=smtp.example.com
MAIL_PORT=587
MAIL_USE_TLS=true
MAIL_USE_SSL=false
MAIL_USERNAME=noreply@example.com
MAIL_PASSWORD=your_smtp_password
MAIL_DEFAULT_SENDER=noreply@example.com

# === HUB SSO (опционально) ===
HUB_URL=https://your-hub.example.com
HUB_CLIENT_ID=your_client_id
HUB_CLIENT_SECRET=your_client_secret
HUB_REDIRECT_URI=https://your-domain.ru/auth/hub/callback

# === LIMITS & RETENTION ===
MAX_FILE_SIZE_MB=4096
JOB_TTL_HOURS=24
AUDIO_RETENTION_DAYS=7
ERROR_LOG_RETENTION_DAYS=30

# === LLM SETTINGS ===
LLM_TIMEOUT_SECONDS=600
LLM_MAX_ATTEMPTS=2
LLM_RETRY_SECONDS=30

# === FLOWER (Celery monitoring) - опционально ===
FLOWER_USER=admin
FLOWER_PASSWORD=change_me_flower_password
