# WhisperX Docker Environment Variables

# API Keys (REQUIRED)
HUGGINGFACE_TOKEN=hf_your_token_here
GEMINI_API_KEY=your_gemini_api_key_here

# Model Configuration
WHISPER_MODEL=large-v3
COMPUTE_TYPE=float16
DEVICE=cuda
BATCH_SIZE=16

# VAD Configuration
VAD_THRESHOLD=0.5
VAD_MIN_SPEECH_MS=250

# Quality Thresholds
SCORE_THRESHOLD=0.25

# Translation
TRANSLATION_CONTEXT_WINDOW=3

# API Configuration
API_HOST=0.0.0.0
API_PORT=8000
CORS_ORIGINS=*

# Redis
REDIS_URL=redis://redis:6379/0

# Logging
LOG_LEVEL=INFO
